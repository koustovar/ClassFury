rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    match /materials/{batchId}/{fileName} {
      allow read: if request.auth != null;
      // Max 20MB for materials
      allow write: if request.auth != null && request.resource.size < 20 * 1024 * 1024;
    }
    
    match /exams/{examId}/{fileName} {
      allow read: if request.auth != null;
      // Max 50MB for exam submissions (documents, images, video)
      allow write: if request.auth != null && request.resource.size < 50 * 1024 * 1024;
    }
    
    match /profile_images/{userId}/{fileName} {
      allow read: if request.auth != null;
      // Users can only write to their own profile folder, max 5MB for images
      allow write: if request.auth != null && request.auth.uid == userId && request.resource.size < 5 * 1024 * 1024;
    }
  }
}
